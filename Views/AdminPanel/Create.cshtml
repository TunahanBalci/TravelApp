@{
    ViewBag.Title = "Create New Entities";
}

<div style="display:flex;justify-content:center;align-items:center">
    <h2 style="font-weight:600">Admin Panel - Create New Entities</h2>
</div>

<div style="display:flex;flex:6;gap:40px;flex-direction:column;justify-content:space-around;align-items:center;margin-top:50px">
    <div>
        <button onclick="location.href='@Url.Action("CreateUser", "CreateUser")'" class="btn btn-primary" style="width:320px;height:60px;border-radius:12px">Create User</button>
    </div>
    <div>
        <button onclick="location.href='@Url.Action("CreateCity", "CreateCity")'" class="btn btn-primary" style="width:320px;height:60px;border-radius:12px">Create City</button>
    </div>
    <div>
        <button onclick="location.href='@Url.Action("CreateAccommodation", "CreateAccommodation")'" class="btn btn-primary" style="width:320px;height:60px;border-radius:12px">Create Accommodation</button>
    </div>
    <div>
        <button onclick="location.href='@Url.Action("CreateReview", "CreateReview")'" class="btn btn-primary" style="width:320px;height:60px;border-radius:12px">Create Review</button>
    </div>
    <div>
        <button onclick="location.href='@Url.Action("CreateDestination", "CreateDestination")'" class="btn btn-primary" style="width:320px;height:60px;border-radius:12px">Create Destination</button>
    </div>
    <div>
        <button onclick="location.href='@Url.Action("CreateActivity", "CreateActivity")'" class="btn btn-primary" style="width:320px;height:60px;border-radius:12px">Create Activity</button>
    </div>

    <div style="margin-top: 50px">
        <button type="button" onclick="location.href='@Url.Action("Index", "AdminPanel")'" class="btn btn-secondary" style="width:320px;height:60px;border-radius:12px">Return</button>
    </div>
</div>
