@model TravelApp.Models.Entities.Destination
@using TravelApp.Models.Entities

@{
    ViewBag.Title = "Create Destination";
}

<h2>Create Destination</h2>

<form asp-action="CreateDestination" asp-controller="AdminPanel" method="post">
    <div style="display: flex; flex-direction:column; gap: 40px;margin-top:50px;margin-bottom:40px">
        <div>
            <label for="Name">Name</label>
            <input type="text" name="Name" id="Name" class="form-control" value="@Model?.Name" required />
            @Html.ValidationMessageFor(model => model.Name, null, new { @class = "text-danger" })
        </div>
        <div>
            <label for="Description">Description</label>
            <textarea name="Description" id="Description" class="form-control">@Model?.Description</textarea>
            @Html.ValidationMessageFor(model => model.Description, null, new { @class = "text-danger" })
        </div>
        <div>
            <label for="Location">Location</label>
            <input type="text" name="Location" id="Location" class="form-control" value="@Model?.Location" required />
            @Html.ValidationMessageFor(model => model.Location, null, new { @class = "text-danger" })
        </div>
        <div>
            <label for="City">City</label>
            <select name="CityId" id="CityId" class="form-control" required>
                <option value="">Select a city</option>
                @if (ViewBag.Cities != null && (ViewBag.Cities as List<City>)?.Any() == true)
                {
                    foreach (var city in ViewBag.Cities as List<City>)
                    {
                        <option value="@city.ID">@city.Name</option>
                    }
                }
                else
                {
                    <option value="">No cities available</option>
                }
            </select>
            @Html.ValidationMessageFor(model => model.City, null, new { @class = "text-danger" })
        </div>

        <div>
            <label for="Attractions">Attractions (Comma-separated)</label>
            <textarea name="Attractions" id="Attractions" class="form-control">@string.Join(", ", Model.Attractions ?? new List<string>())</textarea>
        </div>
    </div>
    <button type="submit" class="btn btn-success">Create</button>
    <button type="button" onclick="location.href='@Url.Action("Index", "AdminPanel")'" class="btn btn-secondary">Return</button>
</form>
