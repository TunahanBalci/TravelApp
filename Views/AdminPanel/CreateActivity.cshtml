@{
    ViewBag.Title = "Create Activity";
}

<h2>Create Activity</h2>

<form asp-action="CreateActivity" asp-controller="AdminPanel" method="post">
    <div style="display: flex; flex-direction:column; gap: 40px;margin-top:50px;margin-bottom:40px">
        <div>
            <label for="Name">Name</label>
            <input type="text" name="Name" id="Name" class="form-control" required />
            @Html.ValidationMessage("Name", "Activity name cannot be null.")
        </div>
        <div>
            <label for="Type">Type</label>
            <input type="text" name="Type" id="Type" class="form-control" required />
            @Html.ValidationMessage("Type", "Type cannot be null.")
        </div>
        <div>
            <label for="Date">Date</label>
            <input type="date" name="Date" id="Date" class="form-control" />
        </div>
        <div>
            <label for="Price">Price</label>
            <input type="number" name="Price" id="Price" step="0.01" class="form-control" />
            @Html.ValidationMessage("Price", "Price must be a valid number.")
        </div>
        <div>
            <label for="Requires_Reservation">Requires Reservation</label>
            <input type="checkbox" name="Requires_Reservation" id="Requires_Reservation" />
        </div>
        <div>
            <label for="Destination_ID">Destination ID</label>
            <input type="text" name="Destination_ID" id="Destination_ID" class="form-control" required />
            @Html.ValidationMessage("Destination_ID", "Destination ID cannot be null.")
        </div>
    </div>
    <button type="submit" class="btn btn-success">Create</button>
    <button type="button" onclick="location.href='@Url.Action("Index", "AdminPanel")'" class="btn btn-secondary">Return</button>
</form>
