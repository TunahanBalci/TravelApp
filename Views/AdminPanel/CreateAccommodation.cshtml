@model TravelApp.Models.Entities.Accommodation

@{
    ViewBag.Title = "Create Accommodation";
}

<h2>Create Accommodation</h2>

<form asp-action="CreateAccommodation" asp-controller="AdminPanel" method="post">
    <div style="display: flex; flex-direction: column; gap: 40px; margin-top: 50px; margin-bottom: 40px">
        <div>
            <label for="Name">Name</label>
            <input type="text" name="Name" id="Name" class="form-control" value="@Model?.Name" required />
            @Html.ValidationMessageFor(model => model.Name, null, new { @class = "text-danger" })
        </div>
        <div>
            <label for="Type">Type</label>
            <input type="text" name="Type" id="Type" class="form-control" value="@Model?.Type" required />
            @Html.ValidationMessageFor(model => model.Type, null, new { @class = "text-danger" })
        </div>
        <div>
            <label for="Location">Location</label>
            <input type="text" name="Location" id="Location" class="form-control" value="@Model?.Location" required />
            @Html.ValidationMessageFor(model => model.Location, null, new { @class = "text-danger" })
        </div>
        <div>
            <label for="Price">Price</label>
            <input type="number" name="Price" id="Price" class="form-control" value="@Model?.Price.ToString()" required />
            @Html.ValidationMessageFor(model => model.Price, null, new { @class = "text-danger" })
        </div>
        <div>
            <label for="Availability">Availability</label>
            <input type="checkbox" name="Availability" id="Availability" />
        </div>
    </div>
    <button type="submit" class="btn btn-success">Create</button>
    <button type="button" onclick="location.href='@Url.Action("Index", "AdminPanel")'" class="btn btn-secondary">Return</button>
</form>
