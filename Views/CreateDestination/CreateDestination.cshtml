@model TravelApp.Models.ViewModels.CreateDestinationViewModel

@{
    ViewBag.Title = "Create Destination";
}

<h2>Create Destination</h2>

<form asp-action="CreateDestination" asp-controller="CreateDestination" method="post">
    <div style="display: flex; flex-direction: column; gap: 40px; margin-top: 50px; margin-bottom: 40px;">
        <!-- Name Field -->
        <div>
            <label for="Name">Name</label>
            <input type="text" asp-for="Name" id="Name" class="form-control" required />
            @Html.ValidationMessageFor(model => model.Name, null, new { @class = "text-danger" })
        </div>

        <!-- Description Field -->
        <div>
            <label for="Description">Description</label>
            <textarea asp-for="Description" id="Description" class="form-control" placeholder="Enter a brief description of the destination"></textarea>
            @Html.ValidationMessageFor(model => model.Description, null, new { @class = "text-danger" })
        </div>

        <!-- Location Field -->
        <div>
            <label for="Location">Location</label>
            <input type="text" asp-for="Location" id="Location" class="form-control" required />
            @Html.ValidationMessageFor(model => model.Location, null, new { @class = "text-danger" })
        </div>

        <!-- City Dropdown -->
        <div>
            <label for="CityID">City</label>
            <select asp-for="CityID"
                    asp-items="@(new SelectList(Model.Cities, "ID", "Name", Model.CityID))"
                    class="form-control" required>
                <option value="">Select a city</option>
            </select>
            @Html.ValidationMessageFor(model => model.CityID, null, new { @class = "text-danger" })
        </div>

        <!-- Activities Checkbox List -->
        <div>
            <label>Activities (@Model.Activities?.Count ?? 0 available)</label>
            @if (Model.Activities != null && Model.Activities.Any())
            {
                foreach (var activity in Model.Activities)
                {
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" name="SelectedActivityIds" id="activity_@activity.ID" value="@activity.ID" />
                        <label class="form-check-label" for="activity_@activity.ID">@activity.Name (@activity.Type)</label>
                    </div>
                }
            }
            else
            {
                <p>No activities available</p>
            }
        </div>

        <!-- Single Attraction Input Field -->
        <div>
            <label for="AttractionsInput">Attraction</label>
            <input type="text" asp-for="AttractionsInput" id="AttractionsInput" class="form-control" placeholder="Enter an attraction" />
            @Html.ValidationMessageFor(model => model.AttractionsInput, null, new { @class = "text-danger" })
        </div>
    </div>

    <!-- Buttons -->
    <button type="submit" class="btn btn-success">Create</button>
    <button type="button" onclick="location.href='@Url.Action("Index", "AdminPanel")'" class="btn btn-secondary">Return</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
